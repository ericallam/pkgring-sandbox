{
  "name": "pkgring-sandbox",
  "version": "0.0.0",
  "private": true,
  "description": "Tracer-bullet sandbox for testing release-branch flows: real npm publishes, real Docker builds, real Helm charts.",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.20.0"
  },
  "scripts": {
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules",
    "changeset:add": "changeset",
    "changeset:version": "changeset version",
    "changeset:release": "turbo build --filter=\"@pkgring/*\" && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "2.27.9",
    "@types/node": "20.17.10",
    "turbo": "2.3.3",
    "typescript": "5.6.3"
  }
}
