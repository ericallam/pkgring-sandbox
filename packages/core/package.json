{
  "name": "@pkgring/core",
  "version": "0.4.0-rc.0",
  "description": "Core primitives for the pkgring sandbox.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ericallam/pkgring-sandbox.git",
    "directory": "packages/core"
  },
  "devDependencies": {
    "tsup": "8.3.5",
    "typescript": "5.6.3"
  }
}
