{
  "name": "@pkgring/cli",
  "version": "0.1.0",
  "description": "CLI that exercises @pkgring/sdk and @pkgring/core.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pkgring": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ericallam/pkgring-sandbox.git",
    "directory": "packages/cli"
  },
  "dependencies": {
    "@pkgring/core": "workspace:*",
    "@pkgring/sdk": "workspace:*"
  },
  "devDependencies": {
    "tsup": "8.3.5",
    "typescript": "5.6.3"
  }
}
